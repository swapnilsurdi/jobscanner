# Copy to .env (gitignored). All values are local-only — do not commit .env.

# Absolute path to a Chrome user-data directory Playwright should use.
# macOS default: "$HOME/Library/Application Support/Google/Chrome"
# Linux default: "$HOME/.config/google-chrome"
# Recommended: create a dedicated profile dir so scans don't interfere with daily browsing.
CHROME_USER_DATA_DIR=

# Optional: specific Chrome profile within the user-data dir (e.g. "Default", "Profile 1").
CHROME_PROFILE_DIRECTORY=Default

# Absolute path to this jobscanner repo (used by the cron wrapper).
JOBSCANNER_DIR=

# Git remote name (default: origin)
GIT_REMOTE=origin

# Git branch (single-branch repo)
GIT_BRANCH=main

# Optional: path to the claude CLI binary if not on PATH
CLAUDE_BIN=claude
