{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--user-data-dir",
        "${CHROME_USER_DATA_DIR}",
        "--browser",
        "chrome"
      ],
      "env": {
        "CHROME_USER_DATA_DIR": "${CHROME_USER_DATA_DIR}",
        "CHROME_PROFILE_DIRECTORY": "${CHROME_PROFILE_DIRECTORY}"
      }
    }
  }
}
